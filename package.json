{
  "name": "kimidesk",
  "version": "1.0.0",
  "description": "Kimi — une petite mascotte qui se balade sur ton bureau Windows.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "dotenv -e .env.local -- electron-builder --mac",
    "dist:all": "dotenv -e .env.local -- electron-builder --win --mac"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.kimidesk.mascot",
    "productName": "KimiDesk",
    "compression": "maximum",
    "removePackageScripts": true,
    "electronLanguages": [
      "fr",
      "en-US"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KimiDesk",
      "artifactName": "KimiDesk-Setup-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "artifactName": "KimiDesk-${version}-${arch}.${ext}",
      "identity": "Jordan Baumard (45UT9NM457)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "KimiDesk"
    },
    "files": [
      "src/**/*",
      "sprites/**/*",
      "!**/*.map",
      "!**/{.eslintrc,.editorconfig,.prettierrc,tsconfig.json}",
      "!**/{README,readme,CHANGELOG,changelog,LICENSE,license}*"
    ]
  }
}
